import numpy as np
import pandas as pd
import matplotlib.pyplot as plt
import seaborn as sns
import shap

from sklearn.model_selection import (
    train_test_split,
    cross_val_score,
    StratifiedKFold
)

from sklearn.impute import SimpleImputer
from sklearn.preprocessing import (
    OneHotEncoder,
    StandardScaler,
    label_binarize
)

from sklearn.compose import ColumnTransformer
from sklearn.pipeline import Pipeline

from sklearn.neural_network import MLPClassifier

from sklearn.metrics import (
    accuracy_score,
    confusion_matrix,
    classification_report,
    roc_curve,
    auc
)
from sklearn.model_selection import GridSearchCV


from sklearn.inspection import permutation_importance
import time

start_time = time.perf_counter()
print("Notebook timing started...") 


df = pd.read_csv("finalcombined_sleep_dataset2.0.csv")

print("Original Shape:", df.shape)

print(df.head())
print(df.info())

target_col = "Sleep Disorder"

X = df.drop(columns=[target_col])
y = df[target_col]

numeric_features = [
    "Age",
    "Sleep Duration",
    "Physical Activity Level",
    "Stress Level"
]

categorical_features = [
    "Gender",
    "Occupation",
    "BMI Category"
]

# Remove rows where target (y) is NaN
mask = y.notna() if hasattr(y, "notna") else ~np.isnan(y)

X_clean = X[mask]
y_clean = y[mask]

# Train-test split
X_train, X_test, y_train, y_test = train_test_split(
    X_clean,
    y_clean,
    test_size=0.20,
    random_state=42,
    stratify=y_clean
)

print("Train Size:", X_train.shape)
print("Test Size:", X_test.shape)

numeric_transformer = Pipeline(steps=[
    ("imputer", SimpleImputer(strategy="median")),
    ("scaler", StandardScaler())
])

categorical_transformer = Pipeline(steps=[
    ("imputer", SimpleImputer(strategy="most_frequent")),
    ("onehot", OneHotEncoder(handle_unknown="ignore"))
])

preprocessor = ColumnTransformer(
    transformers=[
        ("num", numeric_transformer, numeric_features),
        ("cat", categorical_transformer, categorical_features)
    ]
)


baseline_pipeline = Pipeline(steps=[
    ("preprocess", preprocessor),
    ("clf", MLPClassifier(
        max_iter=1000,
        random_state=42
    ))
])

baseline_pipeline.fit(X_train, y_train)

baseline_train_acc = baseline_pipeline.score(X_train, y_train)
baseline_test_acc = baseline_pipeline.score(X_test, y_test)

print("\n===== BASELINE MODEL =====")
print("Training Accuracy:", baseline_train_acc)
print("Testing Accuracy:", baseline_test_acc)

pipeline = Pipeline(steps=[
    ("preprocess", preprocessor),
    ("clf", MLPClassifier(
        max_iter=3000,
        random_state=42
    ))
])

param_grid = {
    "clf__hidden_layer_sizes": [
        (32,),
        (64,),
        (64, 32),
        (128, 64)
    ],
    "clf__activation": [
        "relu",
        "tanh"
    ],
    "clf__alpha": [
        0.0001,
        0.001,
        0.01
    ],
    "clf__learning_rate_init": [
        0.001,
        0.01
    ]
}

cv = StratifiedKFold(
    n_splits=10,
    shuffle=True,
    random_state=42
)

grid_search = GridSearchCV(
    estimator=pipeline,
    param_grid=param_grid,
    cv=cv,
    scoring="accuracy",
    n_jobs=-1
)

grid_search.fit(X_train, y_train)

print("\n===== BEST HYPERPARAMETERS =====")
print(grid_search.best_params_)

import pandas as pd

# Extract results into a DataFrame
results = pd.DataFrame(grid_search.cv_results_)

# Keep only relevant columns
results_table = results[
    [
        "param_clf__hidden_layer_sizes",
        "param_clf__activation",
        "param_clf__alpha",
        "param_clf__learning_rate_init",
        "mean_test_score",
        "std_test_score",
        "rank_test_score"
    ]
]

# Sort by best performance
results_table = results_table.sort_values(by="mean_test_score", ascending=False)

# Reset index for readability
results_table = results_table.reset_index(drop=True)

results_table

best_model = grid_search.best_estimator_

cv_scores = cross_val_score(
    best_model,
    X_train,
    y_train,
    cv=cv,
    scoring="accuracy"
)

print("\nCross Validation Mean Accuracy:",
      cv_scores.mean())

print("Cross Validation Std:",
      cv_scores.std())

tuned_train_acc = best_model.score(X_train, y_train)
tuned_test_acc = best_model.score(X_test, y_test)

print("\n===== TUNED MODEL =====")
print("Training Accuracy:", tuned_train_acc)
print("Testing Accuracy:", tuned_test_acc)

print("\nImprovement:",
      tuned_test_acc - baseline_test_acc)

comparison_df = pd.DataFrame({
    "Model": [
        "Baseline",
        "Baseline",
        "Tuned",
        "Tuned"
    ],
    "Dataset": [
        "Train",
        "Test",
        "Train",
        "Test"
    ],
    "Accuracy": [
        baseline_train_acc,
        baseline_test_acc,
        tuned_train_acc,
        tuned_test_acc
    ]
})

plt.figure(figsize=(8,5))

sns.barplot(
    data=comparison_df,
    x="Model",
    y="Accuracy",
    hue="Dataset"
)

plt.ylim(0,1)
plt.title("Baseline vs Tuned MLP Accuracy")

for container in plt.gca().containers:
    plt.bar_label(container, fmt="%.3f")

plt.tight_layout()
plt.show()

results = pd.DataFrame(grid_search.cv_results_)

results = results.sort_values(
    by="mean_test_score",
    ascending=False
)

top10 = results.head(10)

plt.figure(figsize=(10,5))

plt.bar(
    range(len(top10)),
    top10["mean_test_score"]
)

plt.xticks(
    range(len(top10)),
    top10.index,
    rotation=45
)

plt.ylabel("Cross Validation Accuracy")
plt.xlabel("Top Hyperparameter Combinations")
plt.title("Top 10 Hyperparameter Configurations")

plt.tight_layout()
plt.show()


results = pd.DataFrame(grid_search.cv_results_)

# Sort by best cross-validation score
results = results.sort_values(
    by="mean_test_score",
    ascending=False
)

# Select top 10 configurations
top10 = results.head(10)

# Automatically find all hyperparameter columns
param_cols = [
    col for col in results.columns
    if "param_" in col
]

# Create readable labels for each configuration
labels = []

for _, row in top10.iterrows():

    label = ", ".join(
        [
            f"{col.replace('param_', '')}={row[col]}"
            for col in param_cols
        ]
    )

    labels.append(label)

# Plot
plt.figure(figsize=(14,6))

plt.bar(
    range(len(top10)),
    top10["mean_test_score"]
)

plt.xticks(
    range(len(top10)),
    labels,
    rotation=45,
    ha='right'
)

plt.ylabel("Cross Validation Accuracy")
plt.xlabel("Hyperparameter Combination")
plt.title("Top 10 Hyperparameter Configurations")

plt.tight_layout()
plt.show()

y_test_pred = best_model.predict(X_test)

print("\nAccuracy:",
      accuracy_score(y_test, y_test_pred))

print("\nClassification Report:\n")
print(classification_report(y_test, y_test_pred))

cm = confusion_matrix(
    y_test,
    y_test_pred
)

plt.figure(figsize=(5,4))

sns.heatmap(
    cm,
    annot=True,
    fmt="d",
    cmap="Greens"
)

plt.title("Confusion Matrix")
plt.xlabel("Predicted")
plt.ylabel("Actual")

plt.tight_layout()
plt.show()

y_score = best_model.predict_proba(X_test)

classes = best_model.named_steps["clf"].classes_

y_test_bin = label_binarize(
    y_test,
    classes=classes
)

n_classes = y_test_bin.shape[1]

fpr = {}
tpr = {}
roc_auc = {}

plt.figure(figsize=(8,6))

for i in range(n_classes):

    fpr[i], tpr[i], _ = roc_curve(
        y_test_bin[:, i],
        y_score[:, i]
    )

    roc_auc[i] = auc(
        fpr[i],
        tpr[i]
    )

    plt.plot(
        fpr[i],
        tpr[i],
        label=f"{classes[i]} (AUC = {roc_auc[i]:.2f})"
    )

plt.plot([0,1],[0,1],"k--")

plt.title("ROC Curve")
plt.xlabel("False Positive Rate")
plt.ylabel("True Positive Rate")
plt.legend()

plt.tight_layout()
plt.show()

result = permutation_importance(
    best_model,
    X_test,
    y_test,
    n_repeats=10,
    random_state=42,
    scoring="accuracy"
)

importance_df = pd.DataFrame({
    "Feature": X.columns,
    "Importance": result.importances_mean
})

importance_df = importance_df.sort_values(
    by="Importance",
    ascending=False
)

plt.figure(figsize=(8,5))

plt.barh(
    importance_df["Feature"],
    importance_df["Importance"]
)

plt.gca().invert_yaxis()

plt.title("Permutation Feature Importance")
plt.xlabel("Importance")

plt.tight_layout()
plt.show()

